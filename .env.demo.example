# 外贸手表 Demo 的独立部署配置。请复制为 .env.demo 后修改两项密码。
DEMO_DB_NAME=jsh_erp_trade_demo
DEMO_DB_USER=postgres
DEMO_DB_PASSWORD=请替换为高强度数据库密码
DEMO_REDIS_PASSWORD=请替换为高强度Redis密码

# 同一局域网通过 http://服务器IP:18089 访问。
# 如端口被占用可改为其他未使用端口，例如 18090。
DEMO_WEB_PORT=18089

# AI Token 加密主密钥，至少 16 个字符；生产环境请使用随机长字符串并妥善备份。
AI_CONFIG_MASTER_KEY=replace-with-a-random-string-at-least-32-characters
